{
  "name": "cryptex-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:clean": "npm run clean && vite dev",
    "build": "vite build && node ../scripts/compute-csp-hashes.cjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run",
    "size": "npm run build && size-limit",
    "clean": "node --input-type=module -e \"import fs from 'node:fs';fs.rmSync('node_modules/.vite',{recursive:true,force:true});fs.rmSync('.svelte-kit',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@size-limit/preset-app": "11.1.6",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "autoprefixer": "^10.4.20",
    "bits-ui": "1.8.0",
    "clsx": "^2.1.1",
    "jsdom": "^29.0.2",
    "lucide-svelte": "^0.454.0",
    "mdsvex": "^0.12.7",
    "mode-watcher": "^0.4.1",
    "postcss": "^8.4.49",
    "size-limit": "11.1.6",
    "svelte": "^5.1.9",
    "svelte-check": "^4.0.5",
    "tailwind-merge": "^2.5.4",
    "tailwind-variants": "^0.3.0",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.71",
    "@ai-sdk/openai-compatible": "2.0.41",
    "@openrouter/ai-sdk-provider": "2.8.0",
    "ai": "6.0.168",
    "gpt-tokenizer": "^2.9.0",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "cookie": "^0.7.2"
  }
}
